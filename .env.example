# ============================================================
# Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Google ---
# Path to your Google OAuth credentials file (from Google Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# Google Sheet ID — populated after running google_sheets_setup.py once
SPREADSHEET_ID=

# --- Shopify ---
SHOPIFY_STORE_URL=
SHOPIFY_ACCESS_TOKEN=

# --- Facebook / Meta ---
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT_ID=

# --- Klaviyo ---
KLAVIYO_API_KEY=
# Attribution window in days for Klaviyo revenue (default: 5)
KLAVIYO_ATTRIBUTION_DAYS=5

# --- Email (Gmail API via OAuth2 - no password needed) ---
# Email is sent via the Gmail API using your existing Google OAuth token.
# No App Password or SMTP credentials required.
# Report recipient (same address as sender for self-reporting)
REPORT_EMAIL=

# --- Profit Formula Constants (Footwear Brand Defaults — AUD) ---
# Average cost of goods per order
COGS_PER_ORDER=42.00
# Average shipping/fulfilment cost per order
SHIPPING_PER_ORDER=9.50
# Shopify Payments Australia: percentage fee (as decimal, e.g. 0.0175 = 1.75%)
PAYMENT_FEE_PCT=0.0175
# Shopify Payments Australia: fixed fee per transaction (AUD)
PAYMENT_FEE_FIXED=0.30

# --- General ---
# Set to 'development' or 'production'
ENV=development
